# GridLens local development placeholders.
# Copy to .env for local use and replace values with development-only settings.
# Do not commit real credentials, tokens, tenant data, or regulated data.

APP_ENV=local
LOG_LEVEL=info

API_HOST=0.0.0.0
API_HOST_PORT=8000

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=gridlens_dev
POSTGRES_SUPERUSER=gridlens
POSTGRES_SUPERUSER_PASSWORD=gridlens_local
POSTGRES_MIGRATOR_USER=gridlens_migrator
POSTGRES_MIGRATOR_PASSWORD=gridlens_migrator_local
POSTGRES_APP_USER=gridlens_app
POSTGRES_APP_PASSWORD=gridlens_app_local
MIGRATION_DATABASE_URL=postgresql://gridlens_migrator:gridlens_migrator_local@postgres:5432/gridlens_dev
DATABASE_URL=postgresql://gridlens_app:gridlens_app_local@postgres:5432/gridlens_dev

AWS_PROFILE=gridlens-dev
AWS_REGION=ap-southeast-1
AWS_SDK_LOAD_CONFIG=1

COGNITO_USER_POOL_ID=gridlens-dev-user-pool
COGNITO_CLIENT_ID=gridlens-dev-client
COGNITO_ISSUER=https://cognito-idp.ap-southeast-1.amazonaws.com/gridlens-dev-user-pool
COGNITO_JWKS_URL=https://cognito-idp.ap-southeast-1.amazonaws.com/gridlens-dev-user-pool/.well-known/jwks.json
COGNITO_AUTHORIZATION_URL=https://gridlens-dev.auth.ap-southeast-1.amazoncognito.com/oauth2/authorize
COGNITO_TOKEN_URL=https://gridlens-dev.auth.ap-southeast-1.amazoncognito.com/oauth2/token
COGNITO_REDIRECT_URI=https://oauth.pstmn.io/v1/callback
COGNITO_SCOPES=openid email profile
S3_BUCKET_NAME=gridlens-dev-artifacts
SQS_QUEUE_URL=https://sqs.ap-southeast-1.amazonaws.com/000000000000/gridlens-dev-jobs
BEDROCK_TEXT_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

AUTH_MODE=cognito
GRIDLENS_RUNTIME_MODE=local
SEED_JORDAN_COGNITO_SUB=dev-jordan-lee
SEED_PRIYA_COGNITO_SUB=dev-priya-raman
SEED_MARCUS_COGNITO_SUB=dev-marcus-brooks
SEED_KYLE_COGNITO_SUB=dev-kyle

LLM_PROVIDER=bedrock
RAG_INDEX_NAME=gridlens-dev-index

AUDIT_LOG_ENABLED=true

OBSERVABILITY_MODE=local
LOG_EXPORTER=loki
METRICS_EXPORTER=prometheus
TRACES_EXPORTER=tempo
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OBSERVABILITY_SMOKE_ROUTES_ENABLED=true
UVICORN_ACCESS_LOG_ENABLED=false
OTEL_HTTP_PORT=4318
PROMETHEUS_PORT=9090
LOKI_PORT=3100
TEMPO_PORT=3200
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=gridlens
GRAFANA_ADMIN_PASSWORD=gridlens_local
