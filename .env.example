# GridLens local development placeholders.
# Copy to .env for local use and replace values with development-only settings.
# Do not commit real credentials, tokens, tenant data, or regulated data.

APP_ENV=local
LOG_LEVEL=info

DATABASE_URL=postgresql://gridlens:gridlens@localhost:5432/gridlens_dev

OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_BUCKET=gridlens-dev-bucket
OBJECT_STORAGE_REGION=us-east-1

QUEUE_ENDPOINT=http://localhost:4566/000000000000/gridlens-dev-queue
QUEUE_REGION=us-east-1

AWS_PROFILE=gridlens-dev
AWS_REGION=us-east-1
AWS_SDK_LOAD_CONFIG=1

DEV_AUTH_ENABLED=true
DEV_AUTH_TENANT_ID=tenant_demo
DEV_AUTH_USER_ID=user_demo

LLM_PROVIDER=bedrock
LLM_MODEL_ID=placeholder-model-id
EMBEDDING_MODEL_ID=placeholder-embedding-model-id

RAG_INDEX_NAME=gridlens-dev-index
AUDIT_LOG_ENABLED=true
