# Production observability exporter contract.
# Use this as deployment configuration input; do not put secrets here.

OBSERVABILITY_MODE=production
LOG_EXPORTER=cloudwatch-logs
METRICS_EXPORTER=cloudwatch
TRACES_EXPORTER=xray

AWS_REGION=ap-southeast-1
AWS_XRAY_CONTEXT_MISSING=LOG_ERROR
OTEL_SERVICE_NAME=gridlens
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=production,service.namespace=gridlens

CLOUDWATCH_LOG_GROUP=/gridlens/production/services
CLOUDWATCH_METRIC_NAMESPACE=GridLens/Production
XRAY_TRACE_NAME=gridlens-production
