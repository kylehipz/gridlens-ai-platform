{
  "info": {
    "name": "GridLens Local API",
    "description": "Local Postman requests for the GridLens scaffold API. Kong owns browser-facing /api/v1 traffic; direct service health requests are included for service-local smoke checks.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Gateway",
      "description": "Browser-facing requests served through local Kong.",
      "item": [
        {
          "name": "Health",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('returns JSON', function () {",
                  "  pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test('reports healthy gateway upstream', function () {",
                  "  pm.expect(json.status).to.eql('ok');",
                  "  pm.expect(json.service).to.eql('identity-tenant-service');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/health",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "health"
              ]
            },
            "description": "Validates the browser-facing local gateway path: Kong routes /api/v1/health to the identity tenant service."
          },
          "response": [
            {
              "name": "Healthy",
              "originalRequest": {
                "method": "GET",
                "header": [
                  {
                    "key": "Accept",
                    "value": "application/json"
                  }
                ],
                "url": {
                  "raw": "{{base_url}}/api/v1/health",
                  "host": [
                    "{{base_url}}"
                  ],
                  "path": [
                    "api",
                    "v1",
                    "health"
                  ]
                }
              },
              "status": "OK",
              "code": 200,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"status\": \"ok\",\n  \"service\": \"identity-tenant-service\"\n}"
            }
          ]
        },
        {
          "name": "Create Upload URL",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('returns JSON', function () {",
                  "  pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test('returns authorization placeholder only', function () {",
                  "  pm.expect(json.status).to.eql('authorized');",
                  "  pm.expect(json.tenant_id).to.eql(pm.environment.get('northwind_tenant_id'));",
                  "  pm.expect(json.upload.authorized).to.eql(true);",
                  "  pm.expect(json.upload.storage).to.eql('deferred');",
                  "  pm.expect(json).to.not.have.property('signed_url');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "X-Request-ID",
                "value": "postman-upload-url"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/tenants/{{northwind_tenant_id}}/files/upload-url",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "tenants",
                "{{northwind_tenant_id}}",
                "files",
                "upload-url"
              ]
            },
            "description": "Requests the T08 upload authorization placeholder through Kong. Acquire a Cognito token with OAuth 2.0 Authorization Code with PKCE and store it in the local access_token environment variable first."
          }
        },
        {
          "name": "Unknown Route",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('returns not found', function () {",
                  "  pm.response.to.have.status(404);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/not-found",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "not-found"
              ]
            },
            "description": "Negative smoke check proving the gateway does not accidentally expose undeclared scaffold routes."
          }
        },
        {
          "name": "Observability Smoke",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('returns JSON', function () {",
                  "  pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});",
                  "",
                  "pm.test('echoes request id header', function () {",
                  "  pm.expect(pm.response.headers.get('X-Request-ID')).to.eql(pm.request.headers.get('X-Request-ID'));",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test('emits manual observability signals', function () {",
                  "  pm.expect(json.status).to.eql('ok');",
                  "  pm.expect(json.service).to.eql('identity-tenant-service');",
                  "  pm.expect(json.checks).to.include.members(['log', 'metric', 'trace']);",
                  "  pm.expect(json.trace_id).to.be.a('string').and.not.empty;",
                  "  pm.expect(json.span_id).to.be.a('string').and.not.empty;",
                  "});",
                  "",
                  "pm.collectionVariables.set('observability_trace_id', json.trace_id);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "X-Request-ID",
                "value": "postman-observability-smoke"
              }
            ],
            "url": {
              "raw": "{{base_url}}/__observability/smoke",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "__observability",
                "smoke"
              ]
            },
            "description": "Local-only manual observability route. Emits a JSON log, OTLP metrics to the collector, and a trace visible in Tempo. The returned trace_id is saved as collection variable observability_trace_id."
          },
          "response": [
            {
              "name": "Smoke Emitted",
              "originalRequest": {
                "method": "GET",
                "header": [
                  {
                    "key": "Accept",
                    "value": "application/json"
                  },
                  {
                    "key": "X-Request-ID",
                    "value": "postman-observability-smoke"
                  }
                ],
                "url": {
                  "raw": "{{base_url}}/__observability/smoke",
                  "host": [
                    "{{base_url}}"
                  ],
                  "path": [
                    "__observability",
                    "smoke"
                  ]
                }
              },
              "status": "OK",
              "code": 200,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"status\": \"ok\",\n  \"service\": \"identity-tenant-service\",\n  \"trace_id\": \"trace_id_from_runtime\",\n  \"span_id\": \"span_id_from_runtime\",\n  \"checks\": [\n    \"log\",\n    \"metric\",\n    \"trace\"\n  ]\n}"
            }
          ]
        },
        {
          "name": "Observability Controlled Failure",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('returns 500', function () {",
                  "  pm.response.to.have.status(500);",
                  "});",
                  "",
                  "pm.test('returns JSON', function () {",
                  "  pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});",
                  "",
                  "pm.test('response request id matches header', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.request_id).to.eql(pm.request.headers.get('X-Request-ID'));",
                  "  pm.expect(pm.response.headers.get('X-Request-ID')).to.eql(pm.request.headers.get('X-Request-ID'));",
                  "});",
                  "",
                  "pm.test('returns safe error envelope', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.code).to.eql('internal_error');",
                  "  pm.expect(json.message).to.eql('An unexpected error occurred.');",
                  "  pm.expect(pm.response.text()).to.not.include('token=abc');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "X-Request-ID",
                "value": "postman-observability-fail"
              }
            ],
            "url": {
              "raw": "{{base_url}}/__observability/fail",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "__observability",
                "fail"
              ]
            },
            "description": "Local-only controlled failure route. Verifies safe ErrorEnvelope correlation while emitting failure logs, metrics, and traces through the observability stack."
          },
          "response": [
            {
              "name": "Safe Failure",
              "originalRequest": {
                "method": "GET",
                "header": [
                  {
                    "key": "Accept",
                    "value": "application/json"
                  },
                  {
                    "key": "X-Request-ID",
                    "value": "postman-observability-fail"
                  }
                ],
                "url": {
                  "raw": "{{base_url}}/__observability/fail",
                  "host": [
                    "{{base_url}}"
                  ],
                  "path": [
                    "__observability",
                    "fail"
                  ]
                }
              },
              "status": "Internal Server Error",
              "code": 500,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"code\": \"internal_error\",\n  \"message\": \"An unexpected error occurred.\",\n  \"request_id\": \"postman-observability-fail\"\n}"
            }
          ]
        }
      ]
    },
